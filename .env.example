# ─── Supabase (REQUIRED) ────────────────────────────────────────────────────
# Your project URL from: https://supabase.com/dashboard/project/<id>/settings/api
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Your anon/public key from the same settings page
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Canonical site URL (no trailing slash). Used for OG tags, emails, deep links.
VITE_APP_URL=https://voicetoaction.com

# ─── App Identity (optional) ────────────────────────────────────────────────
# Used for deep-link / OAuth redirect matching. Set to your app bundle ID.
VITE_APP_ID=io.voicetoaction.app

# ─── Feature Flags (optional) ───────────────────────────────────────────────
# Set to "true" to enable the AI petition assistant (requires invoke-llm Edge Function)
VITE_ANTHROPIC_ENABLED=false

# ─── Server / Edge Functions (optional) ─────────────────────────────────────
# OWNER_NOTIFY_EMAIL=inbox-for-delivery-and-report-alerts@example.com

# ─── Deployed Edge Function name for general Stripe Checkout (must match dashboard). Defaults to stripe-checkout.
# VITE_STRIPE_CHECKOUT_FUNCTION=stripe-checkout

# ─── Admin / Owner Configuration ─────────────────────────────────────────────
# Email allowed to trigger Panic Mode (must match OWNER_PANIC_EMAIL on panic-mode Edge Function).
# VITE_OWNER_PANIC_EMAIL=your-owner-email@example.com

# Client-visible support / mailto targets (optional override).
# VITE_SUPPORT_EMAIL=support@voicetoaction.io

# ─── Stripe webhook signing secrets ─────────────────────────────────────────
# Use a separate signing secret per Stripe Dashboard webhook endpoint URL.
# Main payments webhook: STRIPE_WEBHOOK_SECRET=whsec_...
# Blue-check-only webhook (stripe-webhook-blue): STRIPE_WEBHOOK_SECRET_BLUE=whsec_...
# If you only have one endpoint, set STRIPE_WEBHOOK_SECRET; the blue handler falls back to it.

# ─── Scheduled dailyMaintenance ───────────────────────────────────────────
# Set CRON_SECRET in Edge Function env; scheduled jobs must send header x-cron-secret: <same value>.

# Edge Functions (set in Supabase Dashboard): STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET, STRIPE_WEBHOOK_SECRET_BLUE,
# RESEND_API_KEY, OWNER_PANIC_EMAIL, OWNER_NOTIFY_EMAIL, APP_ORIGIN, EMAIL_FROM_NOREPLY, CRON_SECRET, APPLICATION_ID
